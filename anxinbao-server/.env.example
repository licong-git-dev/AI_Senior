# 安心宝环境配置文件示例
# 复制此文件为 .env 并填入真实凭据
#
# ⚠️ 验证：填好后执行
#     cd anxinbao-server && python scripts/check_integrations.py
# 该脚本会逐项打印每个集成是 real/placeholder/missing/weak，杜绝
# "凭据缺失静默走入 mock 模式"在生产环境无人察觉。

# ===================
# 应用基础配置
# ===================
APP_NAME=anxinbao
DEBUG=false
HOST=0.0.0.0
PORT=8000

# ===================
# 数据库配置
# ===================
# SQLite (开发环境)
# DATABASE_URL=sqlite:///./anxinbao.db

# PostgreSQL (生产环境推荐)
DATABASE_URL=postgresql://username:password@localhost:5432/anxinbao

# 数据库连接池配置
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30

# ===================
# Redis配置 (可选)
# ===================
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=
REDIS_MAX_CONNECTIONS=10

# ===================
# JWT认证配置
# ===================
# ⚠️ 务必修改为随机强密钥（≥32 字符），可执行：
#    python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET_KEY=please-replace-with-real-random-key-min-32-chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ===================
# 数据加密密钥（敏感字段加密）
# ===================
# ⚠️ 生产环境必须设置；可执行：
#    python -c "import secrets,base64; print(base64.urlsafe_b64encode(secrets.token_bytes(32)).decode())"
ENCRYPTION_KEY=

# ===================
# AI 服务配置
# ===================
# 阿里云灵积 API（通义千问）
# 获取：https://dashscope.console.aliyun.com/apiKey
DASHSCOPE_API_KEY=
AI_MODEL=qwen-turbo

# OpenAI 兼容接口（可选）
OPENAI_API_KEY=
OPENAI_API_BASE=

# 科大讯飞（语音识别 / 合成 / 方言）
# 获取：https://console.xfyun.cn/services/iat
XFYUN_APPID=
XFYUN_API_KEY=
XFYUN_API_SECRET=

# ===================
# CORS 配置
# ===================
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
# 生产环境：
# ALLOWED_ORIGINS=https://anxinbao.com,https://www.anxinbao.com

# ===================
# 文件存储配置
# ===================
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE=10485760
ALLOWED_FILE_TYPES=.jpg,.jpeg,.png,.gif,.pdf,.doc,.docx

# ===================
# 短信服务配置（阿里云）
# ===================
# ⚠️ 历史命名 SMS_ACCESS_KEY_ID 已通过 AliasChoices 兼容，
#    新代码统一读 ALIYUN_ACCESS_KEY_ID 字段。两套环境变量都能加载。
# 获取：https://ram.console.aliyun.com/users
ALIYUN_ACCESS_KEY_ID=
ALIYUN_ACCESS_KEY_SECRET=
SMS_SIGN_NAME=安心宝
SMS_TEMPLATE_CODE=                     # 普通通知模板
SMS_TEMPLATE_EMERGENCY=                # SOS 紧急模板（必须，否则 SOS 短信发不出）
SMS_TEMPLATE_HEALTH_ALERT=             # 健康告警模板

# ===================
# 推送服务配置（极光推送）
# ===================
# 获取：https://www.jiguang.cn/push
JPUSH_APP_KEY=
JPUSH_MASTER_SECRET=

# ===================
# 支付配置（支付宝 App 支付）
# ===================
# 获取：https://open.alipay.com/develop/manage
ALIPAY_APP_ID=
ALIPAY_PRIVATE_KEY=                    # 应用私钥（完整 PEM，含 -----BEGIN ...）
ALIPAY_PUBLIC_KEY=                     # 支付宝公钥
PAYMENT_NOTIFY_URL=https://api.anxinbao.com/payment/notify/alipay

# ===================
# 邮件服务配置
# ===================
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@anxinbao.com
SMTP_PASSWORD=
SMTP_FROM_NAME=安心宝
SMTP_USE_TLS=true

# ===================
# 日志配置
# ===================
LOG_LEVEL=INFO
LOG_OUTPUT=both                        # console / file / both
LOG_FILE_PATH=./logs/app.log
LOG_FILE_MAX_SIZE=100
LOG_FILE_BACKUP_COUNT=10

# ===================
# 监控配置
# ===================
ENABLE_METRICS=true
METRICS_PATH=/metrics
SENTRY_DSN=

# ===================
# 健康数据告警阈值
# ===================
BP_SYSTOLIC_MIN=90
BP_SYSTOLIC_MAX=140
BP_DIASTOLIC_MIN=60
BP_DIASTOLIC_MAX=90
HR_MIN=60
HR_MAX=100
BS_FASTING_MIN=3.9
BS_FASTING_MAX=6.1
BS_POSTPRANDIAL_MAX=7.8
TEMP_MIN=36.0
TEMP_MAX=37.3

# ===================
# 定时任务配置
# ===================
HEALTH_CHECK_INTERVAL=5
DEVICE_CHECK_INTERVAL=10
MEDICATION_REMINDER_ADVANCE=30

# ===================
# 数据备份配置
# ===================
BACKUP_ENABLED=true
BACKUP_TIME=03:00
BACKUP_RETENTION_DAYS=30
BACKUP_PATH=./backups

# ===================
# 安全配置
# ===================
PASSWORD_MIN_LENGTH=6
LOGIN_FAIL_LOCK_COUNT=5
LOGIN_LOCK_MINUTES=30
SESSION_TIMEOUT=60
