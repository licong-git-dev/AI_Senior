# 安心宝环境配置文件示例
# 复制此文件为 .env 并修改配置值

# ===================
# 应用基础配置
# ===================
APP_NAME=anxinbao
DEBUG=false
HOST=0.0.0.0
PORT=8000

# ===================
# 数据库配置
# ===================
# SQLite (开发环境)
# DATABASE_URL=sqlite:///./anxinbao.db

# PostgreSQL (生产环境推荐)
DATABASE_URL=postgresql://username:password@localhost:5432/anxinbao

# 数据库连接池配置
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30

# ===================
# Redis配置 (可选)
# ===================
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=
REDIS_MAX_CONNECTIONS=10

# ===================
# JWT认证配置
# ===================
# 务必修改为随机强密钥！
JWT_SECRET_KEY=your-super-secret-key-change-this-in-production-min-32-chars
JWT_ALGORITHM=HS256
# Token有效期（分钟）
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ===================
# AI服务配置
# ===================
# 阿里云灵积API（通义千问）
DASHSCOPE_API_KEY=your-dashscope-api-key
# AI模型
AI_MODEL=qwen-turbo

# OpenAI兼容接口（可选）
OPENAI_API_KEY=
OPENAI_API_BASE=

# ===================
# CORS配置
# ===================
# 允许的源，多个用逗号分隔
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
# 生产环境示例
# ALLOWED_ORIGINS=https://anxinbao.com,https://www.anxinbao.com

# ===================
# 文件存储配置
# ===================
UPLOAD_DIR=./uploads
# 最大上传文件大小（字节），默认10MB
MAX_UPLOAD_SIZE=10485760
# 允许的文件类型
ALLOWED_FILE_TYPES=.jpg,.jpeg,.png,.gif,.pdf,.doc,.docx

# ===================
# 短信服务配置
# ===================
# 阿里云短信
SMS_ACCESS_KEY_ID=your-access-key-id
SMS_ACCESS_KEY_SECRET=your-access-key-secret
SMS_SIGN_NAME=安心宝
SMS_TEMPLATE_CODE=SMS_123456789

# ===================
# 推送服务配置
# ===================
# 极光推送
JPUSH_APP_KEY=your-jpush-app-key
JPUSH_MASTER_SECRET=your-jpush-master-secret

# ===================
# 邮件服务配置
# ===================
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@anxinbao.com
SMTP_PASSWORD=your-smtp-password
SMTP_FROM_NAME=安心宝
SMTP_USE_TLS=true

# ===================
# 日志配置
# ===================
LOG_LEVEL=INFO
# 日志输出位置：console, file, both
LOG_OUTPUT=both
LOG_FILE_PATH=./logs/app.log
# 日志文件最大大小（MB）
LOG_FILE_MAX_SIZE=100
# 日志文件保留数量
LOG_FILE_BACKUP_COUNT=10

# ===================
# 监控配置
# ===================
# Prometheus指标
ENABLE_METRICS=true
METRICS_PATH=/metrics

# Sentry错误追踪（可选）
SENTRY_DSN=

# ===================
# 健康数据告警阈值
# ===================
# 血压阈值
BP_SYSTOLIC_MIN=90
BP_SYSTOLIC_MAX=140
BP_DIASTOLIC_MIN=60
BP_DIASTOLIC_MAX=90

# 心率阈值
HR_MIN=60
HR_MAX=100

# 血糖阈值 (mmol/L)
BS_FASTING_MIN=3.9
BS_FASTING_MAX=6.1
BS_POSTPRANDIAL_MAX=7.8

# 体温阈值
TEMP_MIN=36.0
TEMP_MAX=37.3

# ===================
# 定时任务配置
# ===================
# 健康提醒检查间隔（分钟）
HEALTH_CHECK_INTERVAL=5
# 设备离线检查间隔（分钟）
DEVICE_CHECK_INTERVAL=10
# 用药提醒提前时间（分钟）
MEDICATION_REMINDER_ADVANCE=30

# ===================
# 数据备份配置
# ===================
BACKUP_ENABLED=true
BACKUP_TIME=03:00
BACKUP_RETENTION_DAYS=30
BACKUP_PATH=./backups

# ===================
# 安全配置
# ===================
# 密码最小长度
PASSWORD_MIN_LENGTH=6
# 登录失败锁定次数
LOGIN_FAIL_LOCK_COUNT=5
# 登录锁定时间（分钟）
LOGIN_LOCK_MINUTES=30
# 会话超时时间（分钟）
SESSION_TIMEOUT=60
