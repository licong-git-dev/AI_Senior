# 养老智能体系统性能测试配置文件
# 可根据实际环境修改以下配置

# API服务器配置
API_BASE_URL="https://api.eldercare.ai"
API_TIMEOUT=30
API_RETRY_COUNT=3

# 测试配置
DEFAULT_ITERATIONS=100
DEFAULT_CONCURRENT_USERS=50
MONITORING_DURATION=300  # 5分钟
METRICS_INTERVAL=10      # 10秒间隔

# 数据库配置 (用于性能分析)
DB_CONFIG_MYSQL='{
    "type": "mysql",
    "host": "localhost",
    "port": 3306,
    "user": "your_username",
    "password": "your_password",
    "database": "eldercare_db"
}'

DB_CONFIG_POSTGRESQL='{
    "type": "postgresql",
    "host": "localhost",
    "port": 5432,
    "user": "your_username",
    "password": "your_password",
    "database": "eldercare_db"
}'

# 性能阈值配置
PERFORMANCE_THRESHOLDS='{
    "api_response_time": 500,    # API响应时间阈值(ms)
    "database_query_time": 200,  # 数据库查询时间阈值(ms)
    "frontend_load_time": 3000,  # 前端加载时间阈值(ms)
    "error_rate": 0.05           # 错误率阈值(5%)
}'

# 输出目录配置
OUTPUT_DIR="./performance_logs"
REPORT_DIR="./performance_reports"

# 邮件配置 (用于发送性能报告)
EMAIL_CONFIG='{
    "smtp_server": "smtp.gmail.com",
    "smtp_port": 587,
    "username": "your_email@gmail.com",
    "password": "your_app_password",
    "recipients": ["admin@eldercare.ai", "dev-team@eldercare.ai"]
}'

# 告警配置
ALERT_THRESHOLDS='{
    "response_time_critical": 2000,    # 响应时间严重告警阈值(ms)
    "error_rate_warning": 0.02,        # 错误率警告阈值(2%)
    "error_rate_critical": 0.05,       # 错误率严重告警阈值(5%)
    "cpu_usage_warning": 80,           # CPU使用率警告阈值(%)
    "memory_usage_warning": 85         # 内存使用率警告阈值(%)
}'

# 监控配置
MONITORING_CONFIG='{
    "enable_detailed_logging": true,
    "enable_performance_alerts": true,
    "enable_email_notifications": false,
    "enable_slack_notifications": false,
    "slack_webhook_url": "https://hooks.slack.com/services/YOUR/SLACK/WEBHOOK"
}'

# 测试数据配置
TEST_DATA='{
    "test_users": [
        {"id": 1, "name": "张三", "age": 75, "region": "武汉市江岸区"},
        {"id": 2, "name": "李四", "age": 68, "region": "武汉市江岸区"},
        {"id": 3, "name": "王五", "age": 82, "region": "武汉市江岸区"}
    ],
    "health_data_types": ["blood_pressure", "heart_rate", "blood_sugar", "temperature"],
    "device_types": ["smartwatch", "blood_pressure_monitor", "glucometer"]
}'
